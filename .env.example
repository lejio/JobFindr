GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# Stealth worker (Node.js)
WORKER_HOST=127.0.0.1
WORKER_PORT=3847
WORKER_URL=http://127.0.0.1:3847
WORKER_TIMEOUT=120
# Block images/CSS/fonts through proxy to save Decodo bandwidth (default: true)
BLOCK_CSS_IMAGES=true

# Proxy (Decodo / Smartproxy) — required for reliable Google search
# Option A: full proxy URL
# PROXY_URL=http://username:password@gate.decodo.com:10001

# Option B: Decodo credentials (worker rotates ports in range per request)
DECODO_USERNAME=
DECODO_PASSWORD=
DECODO_HOST=gate.decodo.com
DECODO_START_PORT=10001
DECODO_END_PORT=10010

# Option C: legacy single-port Smartproxy format
# SMARTPROXY_USERNAME=
# SMARTPROXY_PASSWORD=
# SMARTPROXY_HOST=gate.decodo.com
# SMARTPROXY_PORT=7000
